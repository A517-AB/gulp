{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./electron/ipc/Jules",
    "outDir": "./dist-jules"
  },
  "include": [
    "electron/ipc/Jules"
  ],
  "exclude": [
    "node_modules",
    "dist-jules"
  ]
}
