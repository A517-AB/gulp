{
  "name": "last",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"vite\"",
    "dev:web": "cross-env VITE_TARGET=web vite",
    "dev:server": "bun --watch run server/index.ts",
    "build": "tsc -b && concurrently \"vite build\" \"npm run build:server\"",
    "build:web": "cross-env VITE_TARGET=web tsc -b && vite build",
    "build:server": "bun build server/index.ts --target bun --outfile dist/server.js",
    "start": "npm run build && concurrently \"electron .\" \"bun run dist/server.js\"",
    "start:web": "npm run build:web && vite preview",
    "start:server": "npm run build:server && bun run dist/server.js",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest",
    "gen:types": "bunx openapi-typescript http://127.0.0.1:3939/openapi.json -o src/renderer/api/jules-api.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/jules-sdk": "^0.2.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/themes": "^3.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.14",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "framer-motion": "^12.40.0",
    "hono": "^4.12.22",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tunnel-rat": "^0.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.1.8",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.1.8",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  }
}
