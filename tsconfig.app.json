{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@renderer": ["./src/renderer/index.ts"],
      "@renderer/*": ["./src/renderer/*"],
      "@shared": ["./src/shared/index.ts"],
      "@shared/*": ["./src/shared/*"],
      "@electron/*": ["./src/electron/*"],
      "@renderer/shell": ["./src/renderer/shell/index.ts"],
      "@renderer/shell/*": ["./src/renderer/shell/*"],
      "@renderer/core": ["./src/renderer/core/index.ts"],
      "@renderer/core/*": ["./src/renderer/core/*"],
      "@/ui": ["./src/renderer/ui"],
      "@/ui/*": ["./src/renderer/ui/*"],
      "@/utils": ["./src/renderer/utils/index.ts"],
      "@/utils/*": ["./src/renderer/utils/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "importHelpers": true,
    "useUnknownInCatchVariables": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
  },
  "include": ["src"],
  "exclude": [
    "src/electron/jules/advanced-session.ts",
    "src/electron/jules/agent.ts",
    "src/electron/jules/basic-session.ts",
    "src/electron/jules/file-system-events.ts"
  ]
}
