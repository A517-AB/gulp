{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@renderer": ["./src/renderer/index.ts"],
      "@renderer/*": ["./src/renderer/*"],
      "@shared": ["./src/shared/index.ts"],
      "@shared/*": ["./src/shared/*"],
      "@electron/*": ["./src/electron/*"],
      "@renderer/shell": ["./src/renderer/shell/index.ts"],
      "@renderer/shell/*": ["./src/renderer/shell/*"],
      "@renderer/core": ["./src/renderer/core/index.ts"],
      "@renderer/core/*": ["./src/renderer/core/*"],
      "@/ui": ["./src/renderer/ui"],
      "@/ui/*": ["./src/renderer/ui/*"],
      "@/utils": ["./src/renderer/utils/index.ts"],
      "@/utils/*": ["./src/renderer/utils/*"],
      "@api": ["./src/renderer/api/index.ts"],
      "@api/*": ["./src/renderer/api/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true
  },
  "include": ["src/electron/**/*.ts", "src/electron/**/*.mts", "vite.config.ts", "src/shared/types.ts", "src/shared/ipc.ts", "src/shared/index.ts"],
  "exclude": []
}
