{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "mainEntryPointFilePath": "./node_modules/@google/jules-sdk/dist/index.d.ts",
  "compiler": {
    "tsconfigFilePath": "./tsconfig.node.json"
  },
  "apiReport": {
    "enabled": false
  },
  "docModel": {
    "enabled": false
  },
  "dtsRollup": {
    "enabled": true,
    "untrimmedFilePath": "./src/types/jules-sdk-rollup.d.ts"
  },
  "messages": {
    "extractorMessageReporting": {
      "default": {
        "logLevel": "none"
      }
    }
  }
}
